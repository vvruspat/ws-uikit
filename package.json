{
  "name": "ws-uikit",
  "version": "0.4.1",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "csstypes": "npx tcm src",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o ./dist-storybook",
    "csstypes:watch": "npx tcm src --watch",
    "postcss": "npx postcss src/**/*.module.css --base src --dir dist",
    "lint": "biome lint --write .",
    "format": "biome check . --write --unsafe",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc --noEmit --project tsconfig.spec.json",
    "verify": "npm-run-all typecheck typecheck:spec check",
    "test": "vitest run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles/index.css": "./src/styles/index.css"
  },
  "dependencies": {
    "biome": "^0.3.3",
    "clsx": "^2.1.1",
    "js-convert-case": "^4.2.0",
    "mime-types": "^3.0.2",
    "react-virtuoso": "^4.18.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "10.2.17",
    "@storybook/addon-docs": "10.2.17",
    "@storybook/addon-links": "10.2.17",
    "@storybook/addon-onboarding": "10.2.17",
    "@storybook/addon-themes": "10.2.17",
    "@storybook/react-vite": "10.2.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "es-css-modules": "^1.2.4",
    "glob": "^13.0.6",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "~16.1.1",
    "postcss-modules": "^6.0.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "~11.2.0",
    "postcss-url": "~10.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "10.2.17",
    "ts-node": "10.9.2",
    "typed-css-modules": "^0.9.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "types": "global-types.d.ts"
}
